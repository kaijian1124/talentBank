# Copy this file to .env.local and fill in your key.
# .env.local is gitignored (matches *.local) so the key stays out of git.

# Your OpenAI API key (server-side only — never exposed to the browser).
OPENAI_API_KEY=

# Model used by the candidate endpoints. GPT-4o mini is the default.
OPENAI_MODEL=gpt-4o-mini

# Port for the local candidate API server (Vite proxies /api here).
PORT=8787

# Supabase client config for login/register and dashboard data.
# Use the anon public key here, not the service-role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
